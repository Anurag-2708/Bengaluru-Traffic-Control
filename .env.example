# GridAI Environment Variables Template
# Copy this file to '.env' and fill in your values.

# 1. Gemini API Key (Optional fallback to rule-based recommendations if left empty)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Port configurations for local execution
BACKEND_PORT=8000
FRONTEND_PORT=8501

# 3. Frontend configuration (Vite requires VITE_ prefix to expose variables to client)
VITE_API_URL=http://localhost:8000

# 4. Allowed CORS Origins for the backend FastAPI app (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
